# ── Clarion app self-observability collector ────────────────
# Copy to `.env` in this directory and fill in. All values come from
# Grafana Cloud → Connections (Prometheus / Loki / Pyroscope "Send …" panels).
# The token is a Cloud Access Policy token with metrics:write + logs:write
# (+ profiles:write if you enable app profiling). Simplest: reuse the SINGLE
# all-scopes token from the project ../../.env (see its "SHIP ALL TELEMETRY"
# banner) so one token covers the app's OTLP path AND this collector.

# Grafana Cloud Prometheus (Mimir) remote-write — "Send Metrics"
GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-XX-prod-REGION.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_USERNAME=000000

# Grafana Cloud Loki remote-write — "Send Logs"
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-XX.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOKI_USERNAME=000000

# Grafana Cloud Pyroscope (Profiles) remote-write — "Send Profiles"
# (only needed if you enable app profiling; see PYROSCOPE_ENABLED in the
# project .env). The collector receives pprof on :4040 and forwards here.
GRAFANA_CLOUD_PYROSCOPE_URL=https://profiles-prod-XXX.grafana.net
GRAFANA_CLOUD_PYROSCOPE_USERNAME=000000

# Cloud Access Policy token (metrics:write + logs:write + profiles:write)
GRAFANA_CLOUD_API_TOKEN=glc_xxx

# Direct DSN to the Clarion Postgres as the least-privilege monitoring
# role created by ../db-observability/init-monitoring-user.sql. NO pooler.
# Local docker postgres published on the host → use host.docker.internal.
#   host.docker.internal:5432  (macOS/Windows, and Linux via extra_hosts)
CLARION_DBO11Y_DSN=postgres://grafana_dbo11y:CHANGE_ME@host.docker.internal:5432/clarion?sslmode=disable
