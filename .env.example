# Anthropic — required for the research and plan agents
ANTHROPIC_API_KEY=sk-ant-...

# Local Postgres (defaults are fine for dev)
POSTGRES_USER=clarion
POSTGRES_PASSWORD=clarion
POSTGRES_DB=clarion
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# === Grafana Cloud — REQUIRED ===
# Visualization (dashboards, alerts, observability) lives on Cloud.
# Local Postgres is just the data source; Cloud reaches it via PDC.
# From your Cloud stack settings page.
GRAFANA_CLOUD_STACK_URL=
GRAFANA_CLOUD_API_TOKEN=

# Datasource UIDs in your Cloud stack. Prometheus / Loki / Tempo default to
# the Cloud-managed names. Postgres has no default — provision a Postgres
# datasource pointing at your local DB via PDC and put its UID here.
# Find UIDs with: `gcx datasources list -o json | jq '.datasources[] | {name,uid}'`
GRAFANA_DS_POSTGRES_UID=
GRAFANA_DS_PROMETHEUS_UID=grafanacloud-prom
GRAFANA_DS_LOKI_UID=grafanacloud-logs
GRAFANA_DS_TEMPO_UID=grafanacloud-traces

# === Grafana Sigil — AI generation observability ===
# Cloud → AI Observability → Configuration. The same access-policy token can be
# reused for SIGIL_AUTH_TOKEN as long as it has the `sigil:write` scope.
# Leave SIGIL_ENDPOINT empty to disable Sigil instrumentation entirely.
SIGIL_ENDPOINT=
SIGIL_PROTOCOL=http
SIGIL_AUTH_MODE=basic
SIGIL_AUTH_TENANT_ID=
SIGIL_AUTH_TOKEN=

# === OTLP — Proj Clarion's telemetry path ===
#
# As of v0.5 there are two routing modes for OTLP. Pick one:
#
# Mode A (default in v0.5+): route through local Alloy
# ----------------------------------------------------
# Bring up Alloy with `docker compose --profile cloud up`. Alloy listens on
# localhost:4317/4318 and forwards to Cloud. Python components (emitter,
# generator, livetail) push to Alloy; Alloy holds the Cloud creds.
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
#   OTEL_EXPORTER_OTLP_HEADERS=
#   GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-<region>.grafana.net/otlp
#   GRAFANA_CLOUD_OTLP_AUTH=Basic <base64("<stack_id>:<access_policy_token>")>
#
# Mode B (legacy v0.4 behavior): direct to Cloud
# ----------------------------------------------
# No Alloy in the loop. Python components push straight to Cloud's OTLP
# gateway. Use this for offline / Alloy-down scenarios.
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-<region>.grafana.net/otlp
#   OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20<base64("<stack_id>:<token>")>
#   GRAFANA_CLOUD_OTLP_ENDPOINT=
#   GRAFANA_CLOUD_OTLP_AUTH=
#
# Find ENDPOINT under your Cloud stack → "Send OpenTelemetry data".
# Find the access-policy token under Cloud → Access Policies. Required scopes
# for the OTLP path: metrics:write, logs:write, traces:write.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# Mimir's OTLP ingester only accepts cumulative temporality. Without this,
# sum metrics emit as delta and Mimir 400s with "invalid temporality and type
# combination for metric ...". Required for Grafana Cloud.
OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=cumulative

# Used by Alloy (Mode A) — Cloud OTLP gateway + auth header.
# Leave empty if running Mode B.
GRAFANA_CLOUD_OTLP_ENDPOINT=
GRAFANA_CLOUD_OTLP_AUTH=

# Clarion's OWN self-observability env. Stamped on every signal the APP
# emits (API server, agents, DB client spans, process metrics) as the OTel
# `deployment.environment` Resource attribute — which Mimir promotes to the
# Asserts `asserts_env` label. Set to `clarion` so the app's own services /
# APIs / infra are filterable in the Knowledge Graph as env=clarion,
# cleanly separated from the per-customer synthetic demo entities (the kg
# EntityEmitter sets env=<customer> explicitly and ignores these vars).
CLARION_ENVIRONMENT=clarion

# Asserts entity scope for the app. Keep in sync with CLARION_ENVIRONMENT
# (Mimir derives the asserts_env label from deployment.environment, so BOTH
# must match or cross-tier joins break). Demo/customer entities override
# this per-build with their own customer slug.
CLARION_ASSERTS_ENV=clarion
CLARION_ASSERTS_SITE=demo

# Continuous profiling (Pyroscope) — OFF by default (adds CPU overhead).
# Set PYROSCOPE_ENABLED=1 to push pprof to the clarion-obs Alloy receiver,
# which forwards to Grafana Cloud Profiles tagged env=clarion. See
# deploy/clarion-obs/.
PYROSCOPE_ENABLED=
PYROSCOPE_SERVER_ADDRESS=http://localhost:4040

# Pre-flight ingest estimate uses this to warn before live-tail saturates
# your Loki tier. Set to your tier's bytes/sec rate limit. Find it in your
# stack settings or in a 429 response body's "limit: NNN bytes/sec" message.
# Leave empty to skip the warning (estimate prints, but never aborts).
# Example for the free/dev tier: 873813
CLARION_LOKI_BYTES_PER_SEC=

# === PDC — only set when you want Cloud to query the local Postgres ===
# From Connections → Private data source connections in your Cloud UI
GCLOUD_PDC_SIGNING_TOKEN=
GCLOUD_HOSTED_GRAFANA_ID=
GCLOUD_PDC_CLUSTER=

# === Research agent settings ===
# Comma-separated list of host patterns the research agent may fetch.
# Wildcards: *.example.com matches subdomains.
# Optional research-fetch allowlist. Empty = allow ANY host (default for
# the public template — any prospect URL works without setup). Set this to
# a comma-separated fnmatch pattern list to restrict the agent's HTTP
# fetches in hardened deployments. Example:
#   RESEARCH_ALLOWED_HOSTS=*.example.com,wikipedia.org,*.sec.gov
RESEARCH_ALLOWED_HOSTS=

# Anthropic model to use (override per-environment)
ANTHROPIC_MODEL=claude-opus-4-7
